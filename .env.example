# Robomuffin Idea Factory — Environment Configuration
# Copy this file to .env and fill in your values.
# Most settings can also be set from the in-app Settings page after first launch;
# .env is the source of truth at startup.

# =============================================================================
# ComfyUI Instances (comma-separated URLs for multi-server dispatch)
# =============================================================================
COMFYUI_URLS=http://192.168.1.100:8188

# =============================================================================
# Whisper Configuration (for lyrics transcription)
# =============================================================================
# Mode: "local" (WhisperX), "remote" (Gradio Whisper-WebUI / OpenAI-compatible),
# or "comfyui" (ComfyUI Whisper workflow on the ComfyUI server itself)
WHISPER_MODE=local
WHISPER_REMOTE_URL=http://192.168.1.100:9000
# WHISPER_COMFYUI_URL=http://192.168.1.100:8188
WHISPER_MODEL=large-v2
# WHISPER_LANGUAGE=English

# =============================================================================
# LLM API Keys (at least one required for prompt enhancement & concept generation)
# =============================================================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local LLM) — comma-separated URLs for multi-instance round-robin
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_URLS=http://192.168.1.50:11434,http://192.168.1.51:11434
# OLLAMA_MODEL=llama3.1

# =============================================================================
# App Settings
# =============================================================================
APP_HOST=127.0.0.1
APP_PORT=8899
PROJECT_DIR=./project_data
LOG_LEVEL=INFO

# =============================================================================
# Export Performance (optional)
# =============================================================================
# Number of clips to render in parallel during export (1 = serial, higher = more
# CPU/GPU pressure but faster). Default 1.
# RBMN_PARALLEL_CLIPS=2

# Override the tmpfs/ramdisk path used for intermediate export files. On Linux,
# /dev/shm is detected automatically. Useful for custom RAM disks on Windows / macOS.
# RBMN_TMPFS_DIR=/path/to/ramdisk

# Minimum free bytes required on the tmpfs candidate before using it.
# Default 2 GiB (2147483648). Falls back to the output directory if not enough free.
# RBMN_TMPFS_MIN_FREE=2147483648

# =============================================================================
# RunPod (optional — for serverless GPU pod management)
# =============================================================================
# RUNPOD_API_KEY=
# RUNPOD_ENABLED=false
